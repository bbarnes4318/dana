# =============================================================================
# Dana Voice Agent — .gitignore
# =============================================================================

# --------------- Environment & Secrets ---------------
.env
.env.*
!.env.example
!.env.production.example

# --------------- SSH / Crypto Keys ---------------
*.pem
*.key
id_rsa
id_ed25519
secrets/
private/

# --------------- Infrastructure State ---------------
infra/hyperstack/last_vm.json

# --------------- Telephony State ---------------
telephony/livekit_trunk_result.json
telephony/last_outbound_call.json
telephony/telnyx_resources.json
telephony/telnyx_dry_run.json
telephony/provisioned.env
telephony/provisioned_resources.json

# --------------- Logs & Backups ---------------
*.log
*.bak
*.backup

# --------------- Python ---------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/

# --------------- IDE ---------------
.vscode/
.idea/
*.swp
*.swo
*~

# --------------- OS ---------------
.DS_Store
Thumbs.db
desktop.ini

# --------------- Docker ---------------
# Don't ignore docker-compose.yaml or Dockerfile — those are tracked.

# --------------- Local Data & Databases ---------------
data/
*.jsonl

