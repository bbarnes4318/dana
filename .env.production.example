# =============================================================================
# Dana Voice Agent - Production Environment Configuration
# =============================================================================
# Copy this file to .env and fill in real values:
#   cp .env.production.example .env
#   nano .env
#
# NEVER commit .env — it contains secrets.
# This file (.env.production.example) contains only safe placeholders.
# =============================================================================

# -----------------------------------------------------------------------------
# HuggingFace Token (required for gated model downloads, e.g. Llama-3.1)
# -----------------------------------------------------------------------------
HF_TOKEN=replace_me

# -----------------------------------------------------------------------------
# LiveKit Configuration (production: LiveKit Cloud)
# -----------------------------------------------------------------------------
LIVEKIT_URL=wss://replace-me.livekit.cloud
LIVEKIT_API_KEY=replace_me
LIVEKIT_API_SECRET=replace_me

# -----------------------------------------------------------------------------
# vLLM Configuration (internal Docker network — do NOT expose publicly)
# -----------------------------------------------------------------------------
VLLM_BASE_URL=http://vllm-server:8000/v1
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
VLLM_MAX_MODEL_LEN=4096
VLLM_GPU_MEMORY_UTILIZATION=0.70
VLLM_QUANTIZATION=fp8
VLLM_ENABLE_PREFIX_CACHING=true

# -----------------------------------------------------------------------------
# Dana Agent — Opening Behavior
# -----------------------------------------------------------------------------
DANA_OPENING_MODE=wait_for_user
DANA_OPENING_LINE=
DANA_AGENT_PROMPT_PATH=prompts/final_expense_alex.md
DANA_AGENT_NAME=Alex
DANA_COMPANY_NAME=American Beneficiary

# -----------------------------------------------------------------------------
# Telnyx API / SIP Management
# -----------------------------------------------------------------------------
TELNYX_API_KEY=replace_me
TELNYX_SIP_ADDRESS=sip.telnyx.com
TELNYX_CONNECTION_ID=
TELNYX_OUTBOUND_VOICE_PROFILE_ID=
TELNYX_PHONE_NUMBER_ID=
TELNYX_OUTBOUND_NUMBER=replace_me
TELNYX_SIP_USERNAME=replace_me
TELNYX_SIP_PASSWORD=replace_me

# -----------------------------------------------------------------------------
# LiveKit SIP / Outbound Calling
# -----------------------------------------------------------------------------
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
DANA_DEFAULT_CALLER_ID=${TELNYX_OUTBOUND_NUMBER}
DANA_ROOM_PREFIX=dana-call
LICENSED_AGENT_PHONE_NUMBER=replace_me

# -----------------------------------------------------------------------------
# Safety Gates
# -----------------------------------------------------------------------------
DANA_CONFIRM_TELNYX_READ=no
DANA_CONFIRM_TELNYX_PROVISION=no
DANA_CONFIRM_TELNYX_MUTATION=no
DANA_CONFIRM_PURCHASE_NUMBER=no
DANA_CONFIRM_CREATE_LIVEKIT_TRUNK=no
DANA_CONFIRM_ACCEPT_UNVERIFIED_LIVEKIT_TRUNK=no
DANA_CONFIRM_PLACE_CALL=no
DANA_CONFIRM_TRANSFER_CALL=no

# -----------------------------------------------------------------------------
# Dana Agent — LLM Inference
# -----------------------------------------------------------------------------
DANA_LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
DANA_MAX_TOKENS=70
DANA_TEMPERATURE=0.45
DANA_TOP_P=0.9

# -----------------------------------------------------------------------------
# Dana Agent — Speech-to-Text (STT)
# -----------------------------------------------------------------------------
DANA_STT_PROVIDER=local
DANA_STT_MODEL=large-v3-turbo
DANA_STT_COMPUTE_TYPE=float16
DANA_VAD_THRESHOLD=0.5
DANA_MIN_SILENCE_MS=180

# -----------------------------------------------------------------------------
# Dana Agent — Text-to-Speech (TTS)
# -----------------------------------------------------------------------------
DANA_TTS_VOICE=af_bella
DANA_TTS_SPEED=1.03

# -----------------------------------------------------------------------------
# Dana Agent — Turn-Taking
# -----------------------------------------------------------------------------
DANA_TURN_MIN_DELAY=0.15
DANA_TURN_MAX_DELAY=0.55
DANA_PREEMPTIVE_GENERATION=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
