# =============================================================================
# Dana Voice Agent - Production Environment Variable Template
# =============================================================================
# Copy this file to .env and fill in real values:
#   cp .env.production.example .env
#   nano .env
#
# NEVER commit the active .env file — it contains sensitive secrets.
# All values here are safe placeholders only.
# =============================================================================

# =============================================================================
# SECTION 1: REQUIRED PRODUCTION ENVIRONMENT VARIABLES
# =============================================================================

# ---- HuggingFace ----
# REQUIRED: Token to download gated models (e.g. Llama-3.1-8B-Instruct) from HuggingFace
HF_TOKEN=replace_me

# ---- LiveKit Cloud ----
# REQUIRED: Connection URL and API credentials for LiveKit Cloud room stack
LIVEKIT_URL=wss://replace-me.livekit.cloud
LIVEKIT_API_KEY=replace_me
LIVEKIT_API_SECRET=replace_me

# ---- LiveKit SIP ----
# REQUIRED: The outbound LiveKit SIP trunk ID registered on LiveKit Cloud console
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=replace_me

# ---- Telnyx ----
# REQUIRED: Telnyx API Key and Connection ID for SIP trunk telephony routing
TELNYX_API_KEY=replace_me
TELNYX_CONNECTION_ID=replace_me

# REQUIRED: Outbound number (or default caller ID). One of these two MUST be set.
TELNYX_OUTBOUND_NUMBER=replace_me
DANA_DEFAULT_CALLER_ID=${TELNYX_OUTBOUND_NUMBER}

# ---- Database ----
# REQUIRED: Postgres database credentials (used by postgres container)
POSTGRES_USER=dana_user
POSTGRES_PASSWORD=replace_with_prod_strong_password
POSTGRES_DB=dana

# REQUIRED: Postgres connection URLs.
# DATABASE_URL connects to PgBouncer pooler (port 6432) for runtime transaction optimization
DATABASE_URL=postgresql://dana_user:replace_with_prod_strong_password@pgbouncer:6432/dana
# DATABASE_ADMIN_URL connects directly to Postgres (port 5432) for running migrations
DATABASE_ADMIN_URL=postgresql://dana_user:replace_with_prod_strong_password@postgres:5432/dana

# ---- Redis ----
# REQUIRED: Redis instance URL and activation flag for hot state storage
REDIS_URL=redis://redis:6379/0
DANA_USE_REDIS_HOT_STATE=true

# ---- vLLM Engine ----
# REQUIRED: Private vLLM model engine configuration
VLLM_BASE_URL=http://vllm-server:8000/v1
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
VLLM_GPU_MEMORY_UTILIZATION=0.70
VLLM_QUANTIZATION=fp8
VLLM_MAX_MODEL_LEN=4096

# ---- Runtime & Safety Defaults ----
# REQUIRED: Set runtime environment constraints to production
DANA_RUNTIME_ENV=production

# REQUIRED: Safety gate. Mock TTS must be blocked in production
DANA_ALLOW_MOCK_TTS=false

# CONTROLLED LIVE CALL TEST MODE
# When true, bulk campaign autodialer ticks are blocked and single outbound call tests can be placed.
# Must be set to false for production campaign execution.
DANA_CONTROLLED_LIVE_TEST=false


# =============================================================================
# SECTION 2: OPTIONAL ENVIRONMENT VARIABLES (SAFE DEFAULTS INCLUDED)
# =============================================================================

# =============================================================================
# EMERGENCY PREMIUM LIVE VOICE MODE
# =============================================================================
# Set DANA_VOICE_MODE=premium_live to bypass the high-latency local voice path
# and route to cloud TTS (ElevenLabs/OpenAI).
# Enforces streaming response, turns off PSTN audio filters, and prevents MockKokoro.
#
# DANA_VOICE_MODE=premium_live
# DANA_TTS_PROVIDER=elevenlabs
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=
# DANA_ENABLE_STREAMING_RESPONSE=true
# DANA_ENABLE_AUDIO_FILTERS=false
#
# Alternatively, use local_cost (NOT recommended for first live customer tests):
# DANA_VOICE_MODE=local_cost

# ---- Optional Cloud Fallbacks (API Keys) ----
# Configure these to enable automatic cloud fallbacks (e.g. OpenAI/ElevenLabs) if local TTS/STT fails
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# ---- Agent Identity & Prompt ----
DANA_AGENT_NAME=Alex
DANA_COMPANY_NAME=American Beneficiary
DANA_AGENT_PROMPT_PATH=prompts/final_expense_alex.md
DANA_OPENING_MODE=wait_for_user
DANA_OPENING_LINE=

# ---- LLM Parameters ----
DANA_LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
DANA_MAX_TOKENS=70
DANA_TEMPERATURE=0.45
DANA_TOP_P=0.9

# ---- Local Speech-to-Text (STT) ----
DANA_STT_PROVIDER=local
DANA_STT_MODEL=large-v3-turbo
DANA_STT_COMPUTE_TYPE=float16
DANA_VAD_THRESHOLD=0.5
DANA_MIN_SILENCE_MS=180

# ---- Local Text-to-Speech (TTS) ----
DANA_TTS_VOICE=af_bella
DANA_TTS_SPEED=1.03

# ---- Turn-Taking ----
DANA_TURN_MIN_DELAY=0.15
DANA_TURN_MAX_DELAY=0.55
DANA_PREEMPTIVE_GENERATION=true

# ---- Interruption Telemetry & Stage Profiles ----
DANA_RECORD_INTERRUPTION_TELEMETRY=true
DANA_ENABLE_FAST_INTERRUPTION=false
DANA_INTERRUPTION_PROFILE=CONSERVATIVE_DEFAULT

# ---- Logging & Operations ----
LOG_LEVEL=INFO
LICENSED_AGENT_PHONE_NUMBER=replace_me

# ---- Write-Behind persistence ----
DANA_WRITE_BEHIND_ENABLED=true
DANA_WRITE_BEHIND_MAX_QUEUE_SIZE=10000
DANA_WRITE_BEHIND_FLUSH_INTERVAL_MS=250
DANA_WRITE_BEHIND_BATCH_SIZE=100

# ---- Redis Key Namespace ----
DANA_REDIS_KEY_PREFIX=dana

# ---- Backups ----
BACKUP_ENABLED=false
BACKUP_TARGET=local
BACKUP_DIR=/var/backups/dana
BACKUP_S3_ENDPOINT=

# =============================================================================
# DEPRECATED ALIASES (FLAGGED BY DEPLOYMENT DOCTOR, DO NOT USE IN PRODUCTION)
# =============================================================================
# DANA_LIVEKIT_SIP_OUTBOUND_TRUNK_ID (use LIVEKIT_SIP_OUTBOUND_TRUNK_ID)
# TELNYX_LIVEKIT_OUTBOUND_TRUNK_ID (use LIVEKIT_SIP_OUTBOUND_TRUNK_ID)
# DANA_ENABLE_AGENT_WORKER (use DANA_AGENT_WORKER_ENABLED)
# DANA_OUTBOUND_CALLER_ID (use TELNYX_OUTBOUND_NUMBER or DANA_DEFAULT_CALLER_ID)
# TELNYX_OUTBOUND_CALLER_ID (use TELNYX_OUTBOUND_NUMBER or DANA_DEFAULT_CALLER_ID)
