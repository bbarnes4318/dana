# Sovereign Voice Stack - Environment Variables

# HuggingFace Token (required for Llama-3.1 download)
HF_TOKEN=your_huggingface_token_here

# LiveKit Configuration
LIVEKIT_URL=wss://your-livekit-server.com
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# vLLM Configuration (internal, usually don't change)
VLLM_BASE_URL=http://vllm-server:8000/v1

# Logging
LOG_LEVEL=INFO

# Telnyx SIP Configuration (for telephony)
TELNYX_SIP_USERNAME=your_sip_username
TELNYX_SIP_PASSWORD=your_sip_password
TELNYX_SIP_DOMAIN=sip.telnyx.com
