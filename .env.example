# Active Telephony Provider Setup
DANA_TELEPHONY_PROVIDER=telnyx
TELNYX_API_KEY=
TELNYX_DIDS=
TELNYX_OUTBOUND_CALLER_ID=
DANA_OUTBOUND_CALLER_ID=

# LiveKit Connection
LIVEKIT_URL=wss://your-livekit-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# LiveKit SIP outbound trunk
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
DANA_TEST_CALL_TO=
DANA_CONFIRM_PLACE_CALL=no
DANA_AGENT_WORKER_ENABLED=true

# Local-first model routing
DANA_STT_ROUTING_MODE=local
DANA_LLM_ROUTING_MODE=local
DANA_TTS_ROUTING_MODE=local
DANA_ALLOW_CLOUD_LLM_FALLBACK=false
DANA_ALLOW_CLOUD_TTS_FALLBACK=false
DANA_CLOUD_STT_ON_FAILURE=false

# Existing compatibility
DANA_CONFIRM_PLACE_CALL=no
SIGNALWIRE_DIDS=

# Additional Options
OPENAI_API_KEY=
DANA_WAIT_UNTIL_ANSWERED=true
DANA_KRISP_ENABLED=true
DANA_LIVEKIT_ROOM_PREFIX=dana
DANA_AGENT_NAME=Dana
DANA_ENABLE_POST_CALL_TRAINING_EXPORT=true
TELEPHONY_LIVE_MODE=false
DANA_ENABLE_OUTBOUND_DIALER=false

# Generic Backups Configuration
BACKUP_ENABLED=false
BACKUP_TARGET=local
BACKUP_DIR=/var/backups/dana
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_ENCRYPTION_KEY=
BACKUP_RETENTION_DAYS=14
