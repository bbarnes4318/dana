# Sovereign Voice Stack - Environment Variables

# HuggingFace Token (required for Llama-3.1 download)
HF_TOKEN=your_huggingface_token_here

# LiveKit Configuration
LIVEKIT_URL=wss://your-livekit-server.com
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# vLLM Configuration (internal, usually don't change)
VLLM_BASE_URL=http://vllm-server:8000/v1

# Logging
LOG_LEVEL=INFO

# SignalWire SIP Configuration (for telephony)
SIGNALWIRE_SIP_USERNAME=your_sip_username
SIGNALWIRE_SIP_PASSWORD=your_sip_password
SIGNALWIRE_SIP_DOMAIN=your-space.sip.signalwire.com

# Database Configuration
# Set DATABASE_URL to use PostgreSQL store. Unset/remove to use local JSONL storage.
DATABASE_URL=postgresql://user:password@localhost:5432/dana

# CRM Webhooks Configuration
DANA_CRM_WEBHOOK_ENABLED=false
DANA_CRM_WEBHOOK_URL=
DANA_CRM_WEBHOOK_SECRET=
DANA_CRM_WEBHOOK_TIMEOUT_SECONDS=5
DANA_CRM_WEBHOOK_MAX_RETRIES=5
DANA_CRM_WEBHOOK_MAX_CONCURRENCY=5
DANA_CRM_SEND_FULL_PHONE=no
DANA_CRM_SEND_TRANSCRIPT=no
DANA_CRM_SEND_RECORDING_URL=no
DANA_ALLOW_MOCK_LIVEKIT_TOKENS=no

# Cost and Metrics Configurations
DANA_COST_STT_RATE_PER_SECOND=
DANA_COST_LLM_PROMPT_RATE_PER_TOKEN=
DANA_COST_LLM_COMPLETION_RATE_PER_TOKEN=
DANA_COST_TTS_RATE_PER_CHARACTER=
DANA_COST_TELEPHONY_RATE_PER_MINUTE=
DANA_COST_LOCAL_STT_INFRA_PER_MINUTE=
DANA_COST_LOCAL_LLM_INFRA_PER_1K_TOKENS=
DANA_COST_LOCAL_TTS_INFRA_PER_1K_CHARS=
DANA_COST_CURRENCY=USD

# Model Routing & Failover Configuration
DANA_MODEL_ROUTING_MODE=local
DANA_LLM_ROUTING_MODE=local
DANA_TTS_ROUTING_MODE=local
DANA_ALLOW_CLOUD_LLM_FALLBACK=false
DANA_ALLOW_CLOUD_TTS_FALLBACK=false
DANA_MODEL_ROUTER_ERROR_WINDOW_SECONDS=300
DANA_MODEL_ROUTER_MAX_ERRORS=3
DANA_MODEL_ROUTER_COOLDOWN_SECONDS=120
DANA_LLM_LOCAL_MAX_RETRIES=1
DANA_TTS_LOCAL_MAX_RETRIES=1
DANA_MAX_LOCAL_CONCURRENT_CALLS=10
DANA_GPU_OVERLOAD_THRESHOLD=0.85
DANA_PREMIUM_CAMPAIGNS=



